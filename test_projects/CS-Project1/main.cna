%reghives = %(HKCR => 0);

include("modules/extra.cna");

sub readbof {
    local('$handle %reghives');
    %reghives = %(HKCR => 0, HKCU => 1);
    $handle = openf(script_resource("bof.o"));
    println("Loaded BOF 1 from " . script_resource("bof.o"));
}

alias project1_cmd {
    readbof();
    external_read();
}
